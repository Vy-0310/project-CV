@model List<CVAnalyzer.WebApp.Models.Cv>
@{
    ViewData["Title"] = "Quản lý Hồ sơ CV";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">@ViewData["Title"]</h2>
        <a asp-action="Upload" asp-controller="Cv" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Phân tích CV mới
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model == null || !Model.Any())
            {
                <div class="text-center p-5">
                    <p class="lead text-muted">Bạn chưa có hồ sơ nào được phân tích.</p>
                    <a asp-action="Upload" asp-controller="Cv" class="btn btn-primary mt-3">Bắt đầu phân tích ngay</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Tên File</th>
                                <th scope="col">Ngày phân tích</th>
                                <th scope="col" class="text-end">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cv in Model)
                            {
                                <tr>
                                    <td><strong>@cv.FileName</strong></td>
                                    <td>@cv.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <a asp-action="Result" asp-controller="Cv" asp-route-id="@cv.Id" class="btn btn-sm btn-outline-info me-2" title="Xem kết quả">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <form asp-action="Delete" asp-controller="Cv" asp-route-id="@cv.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn chắc chắn muốn xóa hồ sơ này?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>