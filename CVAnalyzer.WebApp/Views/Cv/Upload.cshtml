@model CVAnalyzer.WebApp.ViewModels.CvUploadViewModel
@{
    ViewData["Title"] = "Phân tích CV";
}

@section Styles {
    <style>
        /* --- GIỮ NGUYÊN STYLE CŨ CỦA BẠN --- */
        .page-background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: -1;
        }

        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.4;
            z-index: -1;
        }

        .blob-1 {
            top: 10%;
            left: 10%;
            width: 300px;
            height: 300px;
            background: #6366f1;
            animation: float 10s infinite alternate;
        }

        .blob-2 {
            bottom: 20%;
            right: 10%;
            width: 400px;
            height: 400px;
            background: #8b5cf6;
            animation: float 15s infinite alternate-reverse;
        }

        @@keyframes float {
            0% {
                transform: translate(0, 0);
            }

            100% {
                transform: translate(30px, 50px);
            }
        }

        .glass-card {
            background: var(--bs-tertiary-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--bs-border-color-translucent);
            border-radius: 1.5rem;
            box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            height: 100%;
        }

            .glass-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 40px -10px rgba(99, 102, 241, 0.2);
                border-color: rgba(99, 102, 241, 0.3);
            }

        .modern-textarea {
            background-color: var(--bs-body-bg);
            border: 2px solid transparent;
            border-radius: 1rem;
            padding: 1.5rem;
            resize: none;
            transition: all 0.3s ease;
            font-size: 0.95rem;
            line-height: 1.6;
        }

            .modern-textarea:focus {
                border-color: #6366f1;
                box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
                outline: none;
            }

        .drop-zone {
            border: 2px dashed var(--bs-border-color-translucent);
            border-radius: 1rem;
            background-color: var(--bs-body-bg);
            transition: all 0.3s ease;
            position: relative;
            min-height: 280px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            overflow: hidden;
            flex-direction: column;
        }

            .drop-zone:hover {
                border-color: #6366f1;
                background-color: rgba(99, 102, 241, 0.02);
            }

        .drop-zone--over {
            border-color: #6366f1;
            background-color: rgba(99, 102, 241, 0.05);
            transform: scale(0.98);
        }

        .icon-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            color: #6366f1;
            font-size: 2.5rem;
        }

        .btn-gradient-lg {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            color: white;
            border: none;
            padding: 1rem;
            border-radius: 1rem;
            font-weight: 700;
            font-size: 1.1rem;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px -5px rgba(99, 102, 241, 0.4);
        }

            .btn-gradient-lg:hover {
                transform: translateY(-2px);
                box-shadow: 0 15px 30px -5px rgba(99, 102, 241, 0.5);
                color: white;
            }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            z-index: 9999;
            display: none;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        [data-bs-theme="dark"] .loading-overlay {
            background: rgba(15, 23, 42, 0.85);
        }

        .loading-overlay.visible {
            display: flex;
            opacity: 1;
        }

        .loading-card {
            background: var(--bs-tertiary-bg);
            padding: 3rem;
            border-radius: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            max-width: 500px;
            width: 90%;
            text-align: center;
            border: 1px solid var(--bs-border-color-translucent);
        }

        .ai-spinner {
            width: 60px;
            height: 60px;
            border: 4px solid rgba(99, 102, 241, 0.1);
            border-left-color: #6366f1;
            border-radius: 50%;
            margin: 0 auto 1.5rem;
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            100% {
                transform: rotate(360deg);
            }
        }

        /* Style bổ sung cho danh sách nhiều file */
        .drop-zone__thumb {
            width: 100%;
            padding: 10px;
            max-height: 220px;
            overflow-y: auto;
        }
            /* Ẩn thanh cuộn mặc định cho đẹp */
            .drop-zone__thumb::-webkit-scrollbar {
                width: 6px;
            }

            .drop-zone__thumb::-webkit-scrollbar-thumb {
                background-color: rgba(99, 102, 241, 0.2);
                border-radius: 4px;
            }
    </style>
}

<div class="page-background">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
</div>

<div class="container py-5" id="upload-form-container" style="position: relative; z-index: 1;">
    <div class="text-center mb-5">
        <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3 fw-bold border border-primary border-opacity-10">
            🚀 AI-Powered Analysis
        </span>
        <h1 class="display-4 fw-bold mb-3">Tối ưu hóa CV của bạn</h1>
        <p class="lead text-muted col-lg-7 mx-auto">
            Hệ thống hỗ trợ tải lên và phân tích đồng thời nhiều CV. Hãy so sánh các phiên bản để tìm ra bản tốt nhất.
        </p>
    </div>

    <form asp-action="Upload" method="post" enctype="multipart/form-data" id="upload-form">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 shadow-sm border-0 rounded-3"></div>

        <div class="row g-4 justify-content-center">

            <div class="col-lg-6">
                <div class="glass-card p-4 d-flex flex-column">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3 text-primary">
                            <i class="bi bi-briefcase-fill fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Mô tả Công việc (JD)</h5>
                            <small class="text-muted">Dán nội dung tuyển dụng vào đây</small>
                        </div>
                    </div>

                    <textarea asp-for="JobDescription" class="form-control modern-textarea flex-grow-1" rows="12"
                              placeholder="Ví dụ: We are looking for a Senior React Developer with experience in Redux..."></textarea>

                    <div class="mt-3 text-end">
                        <small class="text-muted fst-italic"><i class="bi bi-info-circle me-1"></i>Để trống nếu muốn phân tích tổng quát</small>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="glass-card p-4 d-flex flex-column">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-success bg-opacity-10 p-2 rounded-3 me-3 text-success">
                            <i class="bi bi-person-vcard-fill fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Hồ sơ của bạn</h5>
                            <small class="text-muted">Tải lên một hoặc nhiều file PDF</small>
                        </div>
                    </div>

                    <div class="drop-zone flex-grow-1" id="drop-zone">
                        <input asp-for="CvFiles" type="file" class="drop-zone__input" style="display:none;" multiple required accept=".pdf">

                        <div class="drop-zone__prompt text-center">
                            <div class="icon-circle">
                                <i class="bi bi-cloud-arrow-up-fill"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Kéo thả file vào đây</h5>
                            <p class="text-muted mb-3">hoặc nhấn để duyệt file từ máy</p>
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-10 px-3 py-2">
                                Hỗ trợ nhiều file PDF (Max 5MB/file)
                            </span>
                        </div>

                        <div class="drop-zone__thumb" style="display: none;"></div>
                    </div>

                    <span asp-validation-for="CvFiles" class="text-danger mt-2 d-block text-center fw-medium"></span>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-gradient-lg w-100" id="submit-button">
                            <i class="bi bi-stars me-2"></i>Bắt đầu phân tích AI
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<div id="loading-overlay" class="loading-overlay">
    <div class="loading-card">
        <div class="ai-spinner"></div>
        <h3 class="fw-bold mb-2">Đang xử lý dữ liệu...</h3>
        <p class="text-muted mb-4">Hệ thống đang đọc và phân tích từng hồ sơ của bạn.</p>

        <div class="bg-body-secondary bg-opacity-50 p-3 rounded-3 mt-4">
            <div class="d-flex align-items-center justify-content-center mb-2 text-primary fw-bold">
                <i class="bi bi-lightbulb-fill me-2"></i> Mẹo Hay
            </div>
            <p class="mb-0 text-muted fst-italic tip-text" id="tip-text-container" style="min-height: 3rem;">
                "Đang tải mẹo..."
            </p>
        </div>

        <div class="progress mt-4" style="height: 6px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar" style="width: 100%"></div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dropZone = document.getElementById("drop-zone");
            const input = dropZone.querySelector(".drop-zone__input");
            const prompt = dropZone.querySelector(".drop-zone__prompt");
            const thumb = dropZone.querySelector(".drop-zone__thumb");

            // [QUAN TRỌNG] Tạo đối tượng để lưu trữ danh sách file cộng dồn
            const dt = new DataTransfer();

            dropZone.addEventListener("click", (e) => {
                if(e.target !== input) input.click();
            });

            input.addEventListener("change", () => {
                // Khi chọn file từ máy, thêm vào danh sách chung
                addFiles(input.files);
            });

            dropZone.addEventListener("dragover", (e) => {
                e.preventDefault();
                dropZone.classList.add("drop-zone--over");
            });

            ["dragleave", "dragend"].forEach(type => {
                dropZone.addEventListener(type, () => dropZone.classList.remove("drop-zone--over"));
            });

            dropZone.addEventListener("drop", (e) => {
                e.preventDefault();
                dropZone.classList.remove("drop-zone--over");
                if (e.dataTransfer.files.length) {
                    addFiles(e.dataTransfer.files);
                }
            });

            // Hàm xử lý thêm file (Cộng dồn thay vì ghi đè)
            function addFiles(newFiles) {
                for (let file of newFiles) {
                    // Kiểm tra trùng lặp (nếu cần) hoặc giới hạn file
                    let isDuplicate = false;
                    for (let i = 0; i < dt.files.length; i++) {
                        if (dt.files[i].name === file.name && dt.files[i].size === file.size) {
                            isDuplicate = true;
                            break;
                        }
                    }
                    if (!isDuplicate) {
                        dt.items.add(file);
                    }
                }

                // [QUAN TRỌNG] Cập nhật lại input chính bằng danh sách đã gom
                input.files = dt.files;

                // Hiển thị lại giao diện
                updateThumbnail(dt.files);
            }

            // Hàm xóa file (Nâng cấp thêm nút xóa)
            window.removeFile = function(fileName) {
                const newDt = new DataTransfer();
                for (let file of dt.files) {
                    if (file.name !== fileName) {
                        newDt.items.add(file);
                    }
                }
                dt.items.clear();
                for (let file of newDt.files) dt.items.add(file);

                input.files = dt.files;
                updateThumbnail(dt.files);
            };

            function updateThumbnail(files) {
                // Nếu không có file nào, hiện lại prompt, ẩn danh sách
                if (files.length === 0) {
                    prompt.style.display = "block";
                    thumb.style.display = "none";
                    return;
                }

                prompt.style.display = "none";
                thumb.style.display = "block";
                thumb.innerHTML = "";

                // Tiêu đề
                const summary = document.createElement("div");
                summary.className = "text-center mb-3 text-primary fw-bold sticky-top bg-body py-2 border-bottom";
                summary.style.zIndex = "10";
                summary.innerHTML = `<i class="bi bi-check-circle-fill me-2"></i>Đã chọn ${files.length} file CV`;
                thumb.appendChild(summary);

                // Container cuộn
                const listContainer = document.createElement("div");
                listContainer.style.maxHeight = "200px";
                listContainer.style.overflowY = "auto";

                Array.from(files).forEach(file => {
                    const fileCard = document.createElement("div");
                    fileCard.className = "p-3 rounded-3 border border-success border-opacity-25 bg-success bg-opacity-10 mb-2 d-flex align-items-center justify-content-between";
                    fileCard.innerHTML = `
                        <div class="d-flex align-items-center overflow-hidden">
                            <i class="bi bi-file-earmark-pdf-fill text-success fs-2 me-3 flex-shrink-0"></i>
                            <div class="overflow-hidden">
                                <h6 class="fw-bold text-dark mb-0 text-truncate" title="${file.name}">${file.name}</h6>
                                <small class="text-muted">${(file.size / 1024 / 1024).toFixed(2)} MB</small>
                            </div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger ms-2 border-0" onclick="removeFile('${file.name}')" title="Xóa file này">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    `;
                    listContainer.appendChild(fileCard);
                });
                thumb.appendChild(listContainer);
            }

            // --- Logic Loading Tips (Giữ nguyên) ---
            const form = document.getElementById('upload-form');
            const overlay = document.getElementById('loading-overlay');
            const tipContainer = document.getElementById('tip-text-container');
            const tips = [
                "AI sẽ chấm điểm dựa trên 4 cột trụ: Kỹ năng, Kinh nghiệm, Trình bày và Red Flags.",
                "Hệ thống tự động phát hiện các lỗi mâu thuẫn thời gian trong hồ sơ.",
                "Tùy chỉnh CV phù hợp với từng JD giúp tăng 50% cơ hội phỏng vấn."
            ];

            if (form) {
                form.addEventListener('submit', (e) => {
                    if (input.files.length === 0) {
                        // Chặn submit nếu chưa chọn file
                        alert("Vui lòng chọn ít nhất 1 file CV!");
                        e.preventDefault();
                        return;
                    }

                    if (form.checkValidity()) {
                        document.getElementById('upload-form-container').style.opacity = '0.5';
                        document.getElementById('upload-form-container').style.pointerEvents = 'none';
                        overlay.classList.add('visible');

                        let i = 0;
                        const rotateTips = () => {
                            tipContainer.style.opacity = 0;
                            setTimeout(() => {
                                tipContainer.innerText = tips[i];
                                tipContainer.style.opacity = 1;
                                i = (i + 1) % tips.length;
                            }, 300);
                        };
                        rotateTips();
                        setInterval(rotateTips, 4000);
                    }
                });
            }
        });
    </script>
}