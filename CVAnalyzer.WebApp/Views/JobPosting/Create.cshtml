@model CVAnalyzer.WebApp.ViewModels.JobPostingCreateViewModel

@{
    ViewData["Title"] = "Tạo Vị trí Tuyển dụng mới";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="mb-3">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i> Quay lại Dashboard
                </a>
            </div>

            <div class="card shadow-sm analysis-card">
                <div class="card-header p-3">
                    <h2 class="mb-0 fw-bold">@ViewData["Title"]</h2>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted">
                        Hãy điền thông tin vị trí và dán Mô tả Công việc (JD). AI sẽ sử dụng JD này làm "thước đo" để chấm điểm và xếp hạng tất cả CV được upload cho vị trí này.
                    </p>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fs-5 fw-semibold"></label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="Ví dụ: Senior .NET Developer (C#)">
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="JobDescriptionText" class="form-label fs-5 fw-semibold"></label>
                            <textarea asp-for="JobDescriptionText" class="form-control" rows="15" placeholder="Dán toàn bộ Mô tả Công việc (JD) vào đây..."></textarea>
                            <span asp-validation-for="JobDescriptionText" class="text-danger"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-floppy-fill me-2"></i> Lưu và Tiếp tục
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}